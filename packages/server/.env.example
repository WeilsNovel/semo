# semo 服务端环境变量模板（真实值不入仓，复制为 .env 后填写）
# 约束：API Key 仅在服务端 env，禁止前端持有、禁止硬编码到代码

# 服务端口
PORT=3000
NODE_ENV=development

# 数据库（PostgreSQL/MySQL 二选一）
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=semo
DB_PASSWORD=changeme
DB_DATABASE=semo

# Redis（会话/限流）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_SECRET=changeme
JWT_EXPIRES_IN=7d

# AI 供应商（任选其一启用）
AI_PROVIDER=openai
OPENAI_API_KEY=changeme
OPENAI_BASE_URL=https://api.openai.com/v1
QWEN_API_KEY=
ZHIPU_API_KEY=
DEEPSEEK_API_KEY=

# 微信小程序（登录校验）
MP_APPID=changeme
MP_SECRET=changeme
