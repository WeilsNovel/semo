# semo 服务端环境变量模板（真实值不入仓，复制为 .env 后填写）
# 约束：API Key 仅在服务端 env，禁止前端持有、禁止硬编码到代码

# 服务端口
PORT=3000
NODE_ENV=development

# 数据库（PostgreSQL）
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=semo
DB_PASSWORD=changeme
DB_DATABASE=semo

# Redis（会话/限流，MVP 暂未启用）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT（占位，生产换强随机串）
JWT_SECRET=changeme
JWT_EXPIRES_IN=7d

# AI 供应商（MVP 用智谱 GLM-4V 视觉）
AI_PROVIDER=zhipu
GLM_API_KEY=changeme
GLM_MODEL=glm-4v
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 微信小程序（登录校验；未配置时 login 走 mock openid）
MP_APPID=changeme
MP_SECRET=changeme
